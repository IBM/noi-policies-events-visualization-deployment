[general]
# Port to listen on
port = 5000

# IP address to bind to (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
bind_address = 0.0.0.0

# Directory with CSV files
output_dir = output

# Whether to use SQLite for data storage
use_sqlite = true

# Path to SQLite database file (if use_sqlite is true)
sqlite_path = output/policy_events.db

# Path to event instances export file
event_instances = event_instances_export.csv

# Enable access logging
access_log = true

# Enable debug timing
debug_timing = false

[security]
# Enable CORS (Cross-Origin Resource Sharing)
enable_cors = true

# Allowed origins for CORS (comma-separated, * for all)
cors_origins = *

# Enable basic authentication
enable_auth = false

# Force login page instead of browser popup
force_login_page = false

# Path to users CSV file (username,password_hash)
users_file = users.csv

# Session timeout in minutes (0 to disable)
# Users will be automatically logged out after this period of inactivity
session_timeout = 30

# Audit logging configuration
# Enable audit logging for user actions (login, logout, deployment)
enable_audit = true

# Path to audit log file
audit_log_file = logs/audit.log

# Maximum size of audit log file before rotation (in bytes)
# Default: 10MB
max_log_size = 10485760

# Number of backup log files to keep
backup_count = 5

# HTTPS Configuration
# Enable HTTPS
enable_https = false

# Path to SSL certificate file
ssl_cert_file = cert/cert.pem

# Path to SSL key file
ssl_key_file = cert/key.pem

